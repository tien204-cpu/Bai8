{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@ecommerce/shared-dto": ["libs/shared-dto/src"],
      "@ecommerce/shared-dto/*": ["libs/shared-dto/src/*"],
      "@ecommerce/shared-rmq": ["libs/shared-rmq/src"],
      "@ecommerce/shared-rmq/*": ["libs/shared-rmq/src/*"],
      "@ecommerce/shared-auth": ["libs/shared-auth/src"],
      "@ecommerce/shared-auth/*": ["libs/shared-auth/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
